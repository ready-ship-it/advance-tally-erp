# Flask secret — replace with: python -c "import secrets;print(secrets.token_hex(32))"
SECRET_KEY=change-me-please-use-long-random-string

# DB — Railway provides MYSQL_URL or DATABASE_URL automatically when you add MySQL.
# For local dev only:
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=tally_erp

# Backup
BACKUP_DIR=backups
BACKUP_INTERVAL_HOURS=2
BACKUP_KEEP_LAST=5

# FTP upload (optional)
FTP_HOST=
FTP_USER=
FTP_PASSWORD=
FTP_PORT=21
FTP_REMOTE_DIR=/backups
FTP_USE_TLS=false

# Disable scheduler in CI or one-off commands
ENABLE_SCHEDULER=true
